# Base URL pública en producción (sin slash final)
NEXT_PUBLIC_PRODUCTION_URL=https://savemelin.com

# Opcional para desarrollo local, si necesitas override
# NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# Serper.dev (Google Shopping API)
# Si está seteado, Savemelin lo usa para comparar precios en Google Shopping en vez de scraping HTML.
SERPER_API_KEY=

# Provider selector para comparaciones de Google Shopping:
# - serper: usa Serper cuando hay API key (recomendado)
# - html: fuerza scraping HTML (fallback)
GOOGLE_SHOPPING_PROVIDER=serper

# Límites para proteger costos
SERPER_MAX_NUM=40
SERPER_MAX_RESULTS=5

# Debug (opcional): loggea un preview (truncado) del JSON de Serper.
# Recomendado usar junto con GOOGLE_SHOPPING_DEBUG=true.
SERPER_LOG_RAW=false
